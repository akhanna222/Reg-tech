# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
FI_PORTAL_PORT=3000
TAX_PORTAL_PORT=3002

# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=regtech
DB_USER=regtech
DB_PASSWORD=change_me
DATABASE_URL=postgresql://regtech:change_me@localhost:5432/regtech

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# Object Storage (MinIO / S3-compatible)
# ──────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_RAW=raw-filings
MINIO_BUCKET_PROCESSED=processed-filings
MINIO_BUCKET_PACKAGES=transmission-packages

# ──────────────────────────────────────────────
# Authentication & Security
# ──────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
TOTP_ENCRYPTION_KEY=change_me_32_byte_hex_key
TOTP_ISSUER=RegTech

# ──────────────────────────────────────────────
# SMTP (Email)
# ──────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@regtech.local

# ──────────────────────────────────────────────
# CAPTCHA
# ──────────────────────────────────────────────
CAPTCHA_SECRET=0x0000000000000000000000000000000000000000
CAPTCHA_SITE_KEY=00000000-0000-0000-0000-000000000000

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ──────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ──────────────────────────────────────────────
# CTS SFTP (Default)
# ──────────────────────────────────────────────
CTS_SFTP_DEFAULT_HOST=cts.oecd.org
CTS_SFTP_DEFAULT_PORT=22
CTS_SFTP_DEFAULT_USER=regtech
CTS_SFTP_DEFAULT_KEY_PATH=/etc/reg-tech/keys/sftp/id_rsa
CTS_SFTP_DEFAULT_OUTBOX_PATH=/outbox
CTS_SFTP_DEFAULT_INBOX_PATH=/inbox
CTS_SFTP_DEFAULT_STATUS_OUTBOX_PATH=/status/outbox

# CTS SFTP (Per-jurisdiction overrides — uncomment as needed)
# CTS_SFTP_DE_HOST=cts-de.bzst.de
# CTS_SFTP_DE_PORT=22
# CTS_SFTP_DE_USER=ie-regtech
# CTS_SFTP_DE_KEY_PATH=/etc/reg-tech/keys/sftp/de_id_rsa
# CTS_SFTP_DE_OUTBOX_PATH=/ie/outbox
# CTS_SFTP_DE_INBOX_PATH=/ie/inbox

# ──────────────────────────────────────────────
# CTS Polling (Inbox fallback for inbound data)
# ──────────────────────────────────────────────
CTS_POLLING_ENABLED=true
CTS_POLLING_INTERVAL_CRON=0 */4 * * *
CTS_POLLING_JURISDICTIONS=DE,GB,US
